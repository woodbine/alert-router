# Open Opportunities Alert Router - config.yaml
# Copy this file to config.yaml and fill in your values
#
# Documentation: https://openopps.com/expert

# --- Spend Network API credentials ---
# Sign up at https://openopps.com/pricing (Expert tier)
spend_network:
  api_url: https://api.spendnetwork.cloud  # Spend Network API base URL
  username: your_email@example.com   # Spend Network login email
  password: your_password            # Spend Network password

# --- LLM provider ---
# Used for classifying records against your routing rules
# Uses Google Gemini by default (fast and cost-effective for classification)
llm:
  provider: gemini                   # gemini (default)
  api_key: AIza...                  # your Gemini API key (from aistudio.google.com)
  model: gemini-2.0-flash           # model to use for classification

# --- Search filters ---
# Controls which procurement records are fetched
search:
  # ISO alpha-2 country codes for the buying organisation's country
  # Examples: GB (United Kingdom), IE (Ireland), DE (Germany), FR (France)
  # Use a list for multiple countries: [GB, IE]
  countries: [GB]

  # Minimum contract value in GBP
  # Set to 0 for no minimum
  # Records where the buyer has not published a value are always included
  min_value_gbp: 0

  # Document types to include
  # Available types: tender, planning, tenderUpdate, award, awardUpdate,
  #                  tenderAmendment, planningUpdate, contractUpdate
  contract_types:
    - tender
    - planning
    - tenderUpdate

  # Search term to filter by (searches title, description, and content)
  # Supports boolean OR syntax: "term1" OR "term2" OR "term3"
  # Use this to narrow results to a specific domain
  # Leave blank or remove to fetch all matching records
  search_term: >
    "cyber security" OR "cybersecurity" OR "penetration testing" OR "pen test"
    OR "siem" OR "soc" OR "endpoint" OR "anti-virus" OR "antivirus" OR "firewall"
    OR "information security" OR "data security" OR "network security"
    OR "security operations" OR "threat intelligence" OR "vulnerability"
    OR "intrusion detection" OR "managed security" OR "zero trust"
    OR "identity management" OR "security architecture" OR "red team"
    OR "incident response" OR "security clearance" OR "security audit"
    OR "security monitoring" OR "ransomware" OR "malware" OR "DDoS"
    OR "access control" OR "cyber essentials"

  # Exclude records containing this term (useful for removing false positives)
  # exclude_term: "cleaning"

  # How many days back to query (1 = today only, 2 = today + yesterday)
  lookback_days: 2

  # Records per API page (max 100)
  limit: 100

  # Max total records to fetch (optional - caps total across all pages)
  # Useful for testing. Remove or set to 0 for no cap.
  # max_records: 20

# --- Destinations ---
# Where matched opportunities get posted
# Each destination needs a name, type (teams or slack), and webhook URL
destinations:
  - name: cyber-consulting
    type: teams
    webhook: https://outlook.office.com/webhook/your-webhook-url

  - name: south-east-bd
    type: slack
    webhook: https://hooks.slack.com/services/your-webhook-url

  - name: jane-smith
    type: teams
    webhook: https://outlook.office.com/webhook/another-webhook-url

# --- Routing rules ---
# Plain English descriptions of what each destination should receive.
# The LLM reads these descriptions and matches records accordingly.
# Be specific - include synonyms, geographies, and example organisations.
routing_rules:
  # Example 1: Match by subject matter
  - description: >
      All cyber security consulting, penetration testing, SOC services,
      security architecture, threat intelligence, and red team exercises
    destination: cyber-consulting

  # Example 2: Match by buyer geography
  - description: >
      Any buying organisation that is a local authority, council, or combined
      authority in the South East of England including London, Kent, Surrey,
      Essex, Sussex, and Hampshire
    destination: south-east-bd

  # Example 3: Match by buyer type
  - description: >
      Any opportunity from a central government department, ministry, agency,
      or executive non-departmental public body, including the Home Office,
      NHS England, HMRC, MoD, and similar
    destination: jane-smith
